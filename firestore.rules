rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(currentUid())).data;
    }

    function isAdmin() {
      return signedIn() && currentUserDoc().role == "admin";
    }

    function isTeacher() {
      return signedIn() && currentUserDoc().role == "teacher";
    }

    function isMe(uid) {
      return signedIn() && currentUid() == uid;
    }

    function myTeacherName() {
      return currentUserDoc().teacherName;
    }

    function lessonBelongsToTeacher(data) {
      return isTeacher() &&
        (
          (data.teacherName is string && data.teacherName == myTeacherName()) ||
          (data.teacher is string && data.teacher == myTeacherName())
        );
    }

    function privateStudentBelongsToTeacher(data) {
      return isTeacher() &&
        (data.teacher is string && data.teacher == myTeacherName());
    }

    function groupClassBelongsToTeacher(data) {
      return isTeacher() &&
        (data.teacher is string && data.teacher == myTeacherName());
    }

    function studentPackageBelongsToTeacher(data) {
      return isTeacher() &&
        (data.teacher is string && data.teacher == myTeacherName());
    }

    function creditTransactionBelongsToTeacher(data) {
      return isTeacher() &&
        data.teacher is string &&
        data.teacher == myTeacherName();
    }

    function canManageAttendance() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canManageAttendance == true;
    }

    function canAddStudent() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canAddStudent == true;
    }

    function canEditStudent() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canEditStudent == true;
    }

    function canDeleteStudent() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canDeleteStudent == true;
    }

    function canEditLesson() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canEditLesson == true;
    }

    function canDeleteLesson() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canDeleteLesson == true;
    }

    function canCreateLessonDirectly() {
      return signedIn() &&
        currentUserDoc().role == "teacher" &&
        currentUserDoc().canCreateLessonDirectly == true &&
        currentUserDoc().requiresLessonApproval != true;
    }

    function canTeacherUpdateStudentPackageUsage() {
      return canManageAttendance() ||
        canCreateLessonDirectly() ||
        canEditLesson() ||
        canDeleteLesson();
    }

    function parentGroupClassBelongsToTeacher(groupClassId) {
      return isTeacher() &&
        get(/databases/$(database)/documents/groupClasses/$(groupClassId)).data.teacher == myTeacherName();
    }

    /** canonical groupClassId 우선, 없으면 iOS legacy groupClassID, 없으면 classID */
    function effectiveGroupClassIdFromData(data) {
      return data.groupClassId is string ? data.groupClassId
        : (data.groupClassID is string ? data.groupClassID
          : (data.classID is string ? data.classID : ""));
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{uid} {
      allow read: if isMe(uid) || isAdmin();
      allow create: if isMe(uid) || isAdmin();
      allow update: if isMe(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isAdmin() || lessonBelongsToTeacher(resource.data);
      allow create: if isAdmin() || (
        canCreateLessonDirectly() &&
        lessonBelongsToTeacher(request.resource.data)
      );
      allow update: if isAdmin() || (
        canEditLesson() &&
        lessonBelongsToTeacher(resource.data) &&
        lessonBelongsToTeacher(request.resource.data) &&
        changedOnly(["date", "time", "subject", "startAt", "updatedAt"])
      ) || (
        canManageAttendance() &&
        lessonBelongsToTeacher(resource.data) &&
        lessonBelongsToTeacher(request.resource.data) &&
        changedOnly([
          "isDeductCancelled",
          "deductMemo",
          "updatedAt",
          "studentId",
          "studentName",
          "teacherName"
        ])
      );
      allow delete: if isAdmin() || (
        canDeleteLesson() &&
        lessonBelongsToTeacher(resource.data)
      );
    }

    match /privateStudents/{studentId} {
      allow read: if isAdmin() || privateStudentBelongsToTeacher(resource.data);
      allow create: if isAdmin() || (
        canAddStudent() &&
        privateStudentBelongsToTeacher(request.resource.data)
      );
      allow update: if isAdmin() || (
        canEditStudent() &&
        privateStudentBelongsToTeacher(resource.data) &&
        privateStudentBelongsToTeacher(request.resource.data) &&
        changedOnly([
          "name",
          "teacher",
          "phone",
          "carNumber",
          "learningPurpose",
          "firstRegisteredAt",
          "note",
          "updatedAt"
        ])
      ) || (
        canManageAttendance() &&
        privateStudentBelongsToTeacher(resource.data) &&
        changedOnly(["attendanceCount", "updatedAt"])
      );
      allow delete: if isAdmin() || (
        canDeleteStudent() &&
        privateStudentBelongsToTeacher(resource.data)
      );
    }

    match /groupClasses/{groupClassId} {
      allow read: if isAdmin() || groupClassBelongsToTeacher(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /groupStudents/{groupStudentId} {
      allow read: if isAdmin() || (
        isTeacher() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data))
      );

      allow create: if isAdmin() || (
        canAddStudent() &&
        effectiveGroupClassIdFromData(request.resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(request.resource.data))
      );

      allow update: if isAdmin() || (
        canManageAttendance() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        effectiveGroupClassIdFromData(request.resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data)) &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(request.resource.data)) &&
        changedOnly(["attendanceCount", "updatedAt"])
      );

      allow delete: if isAdmin() || (
        canDeleteStudent() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data))
      );
    }

    match /groupLessons/{groupLessonId} {
      allow read: if isAdmin() || (
        isTeacher() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data))
      );

      allow create: if isAdmin() || (
        canCreateLessonDirectly() &&
        effectiveGroupClassIdFromData(request.resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(request.resource.data))
      );

      allow update: if isAdmin() || (
        canEditLesson() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        effectiveGroupClassIdFromData(request.resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data)) &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(request.resource.data)) &&
        changedOnly([
          "groupClassId",
          "groupClassName",
          "teacher",
          "date",
          "time",
          "subject",
          "updatedAt"
        ])
      ) || (
        canManageAttendance() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        effectiveGroupClassIdFromData(request.resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data)) &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(request.resource.data)) &&
        changedOnly(["countedStudentIDs", "attendanceAppliedAt", "updatedAt"])
      );

      allow delete: if isAdmin() || (
        canDeleteLesson() &&
        effectiveGroupClassIdFromData(resource.data) != "" &&
        parentGroupClassBelongsToTeacher(effectiveGroupClassIdFromData(resource.data))
      );
    }

    match /studentPackages/{packageId} {
      allow read: if isAdmin() || studentPackageBelongsToTeacher(resource.data);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        canTeacherUpdateStudentPackageUsage() &&
        studentPackageBelongsToTeacher(resource.data) &&
        studentPackageBelongsToTeacher(request.resource.data) &&
        changedOnly(["usedCount", "remainingCount", "status", "updatedAt"])
      );
      allow delete: if isAdmin();
    }

    match /creditTransactions/{txId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || canManageAttendance();
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
